{
    "name": "hydra/kernel",
    "description": "Default composition root and HTTP plumbing for the Hydra PHP framework",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Hydra\\Kernel\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Hydra\\Kernel\\Tests\\": "tests/"
        }
    },
    "repositories": [
        { "type": "path", "url": "../core", "options": { "symlink": true } },
        { "type": "path", "url": "../http", "options": { "symlink": true } },
        { "type": "path", "url": "../session", "options": { "symlink": true } },
        { "type": "path", "url": "../event", "options": { "symlink": true } },
        { "type": "path", "url": "../auth", "options": { "symlink": true } },
        { "type": "path", "url": "../authorization", "options": { "symlink": true } },
        { "type": "path", "url": "../nyholm", "options": { "symlink": true } },
        { "type": "path", "url": "../view", "options": { "symlink": true } },
        { "type": "path", "url": "../csrf", "options": { "symlink": true } }
    ],
    "authors": [
        {
            "name": "William Hleucka",
            "email": "william.hleucka@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.2",
        "hydra/core": "*",
        "hydra/http": "*",
        "hydra/session": "*",
        "hydra/event": "*",
        "hydra/auth": "*",
        "hydra/authorization": "*",
        "hydra/nyholm": "*",
        "hydra/view": "*",
        "psr/http-message": "^2.0",
        "psr/http-server-handler": "^1.0",
        "psr/http-server-middleware": "^1.0",
        "nyholm/psr7": "^1.8"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
